# MMD Delivery — Final production certification (template)
# Copy to: apps/web/.env.local  OR  docs/production/final-certification.env
# NEVER commit real secrets. Add final-certification.env to .gitignore if stored locally.

# --- Production API ---
PROD_BASE_URL=https://www.mmddelivery.com

# --- Supabase (production project) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...your_anon_key...
# Optional — enables DB read checks in the Node script (keep private):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...

# --- Test client (optional — enables food/delivery/taxi API probes) ---
# Paste a fresh access_token from a test client user (Supabase session):
TEST_CLIENT_JWT=

# Scope for US market probes (query string on food/delivery routes):
CERTIFICATION_SCOPE_COUNTRY=US
CERTIFICATION_SCOPE_LAT=40.7128
CERTIFICATION_SCOPE_LNG=-74.0060

# Food probe data (real approved restaurant + menu item in prod):
CERTIFICATION_RESTAURANT_USER_ID=
CERTIFICATION_MENU_ITEM_ID=

# Restaurant Command Center API validation (device + script):
# CERTIFICATION_RESTAURANT_EMAIL=
# CERTIFICATION_RESTAURANT_PASSWORD=
# CERTIFICATION_RESTAURANT_ACCESS_TOKEN=
# CERTIFICATION_OTHER_RESTAURANT_USER_ID=
# COMMAND_CENTER_REPORT_PATH=docs/production/reports/restaurant-command-center-validation.json

# --- Cron / monitoring (optional — READ ONLY dispatch retry probes) ---
CRON_SECRET=

# WARNING: process-payouts can move real money. Leave false unless you intend a payout dry-run review.
CERTIFICATION_ALLOW_PAYOUT_CRON=false

# --- Create unpaid rows (optional — NO Stripe charge) ---
CERTIFICATION_ALLOW_CREATE=false

# --- Live Stripe payment E2E (explicit opt-in only) ---
CERTIFICATION_ALLOW_LIVE_PAYMENT=false

# --- RLS probe via user JWT (attempts INSERT, expects rejection) ---
CERTIFICATION_ALLOW_RLS_PROBE=false

# --- Supabase SQL sign-off (after final_certification_checks.sql in prod) ---
SUPABASE_TRUST_BOUNDARY_SQL_DONE=false
SUPABASE_TRUST_BOUNDARY_SQL_VALIDATED_AT=

# --- Manual ops confirmations (set true after you verify in dashboards) ---
STRIPE_DASHBOARD_CHECK_DONE=false
STRIPE_UNIQUE_WEBHOOK_CONFIRMED=false
EDGE_WEBHOOK_DISABLED_CONFIRMED=false
TESTFLIGHT_US_CHECK_DONE=false
TESTFLIGHT_GN_CHECK_DONE=false
ANDROID_US_CHECK_DONE=false
ANDROID_GN_CHECK_DONE=false

# --- Report output ---
CERTIFICATION_REPORT_PATH=docs/production/reports/final-certification-report.json
