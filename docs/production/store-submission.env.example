UNIVERSAL_LINKS_DEVICE_CHECK_DONE=false
TWILIO_E2E_MASKED_CALL_DONE=false

# Play submit — file must exist locally at repo root (never commit):
PLAY_SERVICE_ACCOUNT_READY=false

# Commercial launch — ops / legal / business:
EXTERNAL_DISPATCH_CRON_CONFIGURED=false
SMS_A2P_10DLC_US_DONE=false
LIVE_PAYMENT_E2E_SIGNOFF_DONE=false

REPORT_PATH=docs/production/reports/store-submission-readiness.json
