# Store Submission + Commercial Launch certification (template)
# Copy to: docs/production/store-submission.env (gitignored)
# Usage: node apps/web/scripts/store-submission-readiness.mjs --env docs/production/store-submission.env

PROD_BASE_URL=https://www.mmddelivery.com
SUPABASE_PROJECT_REF=sjmszohmhudayxawfows

# Optional — enables Edge push key probes (never commit):
# PUSH_API_KEY=

# Optional — enables authenticated Edge onboarding 410 probe:
# SUPABASE_ANON_KEY=

# --- Manual sign-offs (set true after completing checklists) ---
# Device-only — required before Play/App Store upload, NOT before EAS build:
