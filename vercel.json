{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily-money",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron/daily-ops",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/process-finance",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/retry-delivery-request-dispatch",
      "schedule": "*/2 * * * *"
    }
  ]
}
