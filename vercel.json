{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/admin/process-payouts",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/orders/expire-unpaid",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/taxi-monitoring-snapshot",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/vehicle-eligibility-refresh",
      "schedule": "5 0 * * *"
    }
  ]
}
