{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/admin/process-payouts",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/expire-stale-payments",
      "schedule": "15 5 * * *"
    },
    {
      "path": "/api/cron/taxi-payouts",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/marketplace-payouts",
      "schedule": "45 4 * * *"
    },
    {
      "path": "/api/cron/taxi-monitoring-snapshot",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/vehicle-eligibility-refresh",
      "schedule": "5 0 * * *"
    }
  ]
}
