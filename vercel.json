{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",

  "crons": [
    {
      "path": "/api/admin/process-payouts",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/orders/expire-unpaid",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/retry-taxi-dispatch",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/taxi-scheduled-dispatch",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/taxi-monitoring-snapshot",
      "schedule": "*/15 * * * *"
    }
  ]
}