# App
NEXT_PUBLIC_SITE_URL=https://www.mmddelivery.com
NEXT_PUBLIC_APP_NAME="MMD Delivery"
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# Ops / cron
CRON_SECRET=
MONITORING_SECRET=
MONITORING_WEBHOOK_URL=
DISPATCH_INTERNAL_SECRET=
MMD_PAYOUT_MODE=hybrid

# Platform scope experience control (rollback-safe; default = country-only backend gates)
PLATFORM_SCOPE_GATES_ENABLED=false
PLATFORM_US_STATE_GATES=false
PLATFORM_GN_ZONE_GATES=false
PLATFORM_UI_FEATURES_ONLY=false

# Delivery pricing V2 shadow (logs only — V1 remains billing source of truth)
DELIVERY_PRICING_V2_SHADOW_ENABLED=false

# Marketplace checkout (shadow architecture — no live Stripe by default)
MARKETPLACE_CHECKOUT_ENABLED=false

# Marketplace live checkout (Stripe Checkout Session — OFF by default)
MARKETPLACE_CHECKOUT_LIVE_ENABLED=false

# Marketplace delivery/dispatch shadow (no live dispatch or driver notifications)
MARKETPLACE_DELIVERY_SHADOW_ENABLED=false

# Marketplace live dispatch (driver assignment — OFF by default)
MARKETPLACE_DISPATCH_LIVE_ENABLED=false

# Marketplace payouts (seller + driver ledgers — OFF by default, no Stripe transfers)
MARKETPLACE_PAYOUTS_LIVE_ENABLED=false

# Mobile (EAS)
EXPO_PUBLIC_API_URL_PROD=https://www.mmddelivery.com
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_STRIPE_PK=
