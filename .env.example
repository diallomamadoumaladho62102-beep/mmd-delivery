EXPO_PUBLIC_LEGAL_TERMS_URL=https://www.mmddelivery.com/legal/terms
EXPO_PUBLIC_SUPPORT_URL=https://www.mmddelivery.com/legal/support
# Must remain unset or 0 for production store builds:
EXPO_PUBLIC_DRIVER_NAV_PREVIEW=

