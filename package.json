{
  "name": "mmd-delivery",
  "private": true,
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "cd apps/web && pnpm dev",
    "build": "cd apps/web && pnpm build",
    "start": "cd apps/web && pnpm start",
    "test:ci": "node scripts/verify-migration-files.mjs && node scripts/verify-profiles-signup-role-guard.mjs && node scripts/evaluateCronHttpResult.test.mjs && node scripts/secret-scan.mjs && pnpm --dir apps/web test:ci && pnpm --dir apps/mobile test:navigation",
    "test:security": "node scripts/secret-scan.mjs && pnpm --dir apps/web test:security",
    "test:performance": "pnpm --dir apps/web test:performance && node scripts/bundle-size-report.mjs",
    "test:ui": "pnpm --dir apps/mobile test:ui && pnpm --dir apps/web test:ui",
    "lighthouse:smoke": "node scripts/lighthouse-smoke.mjs",
    "audit:deps": "node scripts/dependency-audit.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@rnmapbox/maps": "^10.3.0",
    "@sentry/cli": "2.55.0",
    "@sentry/react-native": "~7.2.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "^2.80.0",
    "base64-arraybuffer": "^1.0.2",
    "dotenv": "^17.2.3",
    "expo": "~54.0.36",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.7",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.19",
    "expo-web-browser": "~57.0.1",
    "i18next": "^25.10.10",
    "react": "19.1.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "5"
  },
  "pnpm": {
    "overrides": {
      "expo-keep-awake": "~15.0.8",
      "undici": "6.23.0",
      "next": ">=16.2.6",
      "ws": ">=8.21.0",
      "tar": ">=7.5.11",
      "minimatch": ">=3.1.3",
      "shell-quote": ">=1.8.4",
      "node-forge": ">=1.4.0",
      "picomatch": ">=2.3.2",
      "@xmldom/xmldom": ">=0.8.13",
      "fast-uri": ">=3.1.2",
      "@isaacs/brace-expansion": ">=5.0.1"
    }
  }
}
