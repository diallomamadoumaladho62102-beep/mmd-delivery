"use client";
import { useEffect, useState } from "react";
import { supabase } from "@/lib/supabaseBrowser";

type OC = {
  client_pct: number; driver_pct: number; restaurant_pct: number; platform_pct: number;
  client_amount: number; driver_amount: number; restaurant_amount: number; platform_amount: number;
  currency: string;
};
type OrderInfo = { order_type: "food" | "errand" | string; subtotal: number; delivery_fee: number; };

export default function CommissionSummary({ orderId }: { orderId: string }) {
  const [c, setC] = useState<OC | null>(null);
  const [o, setO] = useState<OrderInfo | null>(null);
  const [err, setErr] = useState<string | null>(null);

  const money = (x: number, cur = "USD") => `${x.toFixed(2)} ${cur}`;

  async function load() {
    const [{ data: oc, error: e1 }, { data: ord, error: e2 }] = await Promise.all([
      supabase.from("order_commissions").select("*").eq("order_id", orderId).maybeSingle(),
      supabase.from("orders").select("order_type, subtotal, delivery_fee").eq("id", orderId).maybeSingle(),
    ]);
    if (e1) setErr(e1.message);
    else setC(oc as any);
    if (!e2 && ord) setO(ord as any);
  }

  useEffect(() => { load(); }, [orderId]);

  if (err) return <div className="text-red-600">{err}</div>;
  if (!c) return <div>Chargement…</div>;

  return (
    <div className="space-y-2">
      {o && (
        <div className="text-sm text-gray-600">
          Type: <b>{o.order_type || "?"}</b>
          {o.order_type === "food" && (
            <span className="ml-2 text-xs">
              (repas {money(o.subtotal, c.currency)} • livraison {money(o.delivery_fee, c.currency)})
            </span>
          )}
        </div>
      )}

      <div className="grid grid-cols-2 gap-2 text-sm">
        <div>Client: {c.client_pct}% • <b>{money(c.client_amount, c.currency)}</b></div>
        <div>Driver: {c.driver_pct}% • <b>{money(c.driver_amount, c.currency)}</b></div>
        <div>Restaurant: {c.restaurant_pct}% • <b>{money(c.restaurant_amount, c.currency)}</b></div>
        <div>Plateforme: {c.platform_pct}% • <b>{money(c.platform_amount, c.currency)}</b></div>
      </div>

      {o?.order_type === "food" && (
        <div className="text-xs text-gray-500">
          Détail (food) : Plateforme = 15% repas + 10% livraison • Restaurant = 85% repas • Driver = 90% livraison
        </div>
      )}
    </div>
  );
}
