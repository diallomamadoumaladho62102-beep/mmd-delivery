"use client";
import { useEffect, useState } from "react";
import { useParams } from "next/navigation"; import { useSearchParams } from "next/navigation";
import { supabase } from "@/lib/supabaseBrowser";
import MembersList from "@/components/MembersList";
import { useOrderMembership } from "@/hooks/useOrderMembership";

type Order = {
  id: string;
  status: "pending"|"accepted"|"prepared"|"ready"|"dispatched"|"delivered"|"canceled";
  subtotal: number;
  currency: string;
};

type CommissionRow = {
  order_id: string;
  currency: string;
  client_amount?: number | string | null;
  driver_amount?: number | string | null;
  restaurant_amount?: number | string | null;
  platform_amount?: number | string | null;
  updated_at?: string | null;
  client_cents?: number | null;
  driver_cents?: number | null;
  restaurant_cents?: number | null;
  platform_cents?: number | null;
};

function to2(n: number | string | null | undefined) {
  if (n === null || n === undefined) return "0.00";
  const num = typeof n === "number" ? n : parseFloat(String(n));
  if (Number.isNaN(num)) return "0.00";
  return num.toFixed(2);
}

export default function OrderPage() {
  const searchParams = useSearchParams();
  const params = useParams<{ orderId?: string }>();
  const orderId = (params?.orderId ?? "").toString();
  const [order, setOrder] = useState<Order | null>(null);
  
  // Auto-join DEV (ex: ?autoJoin=driver)
  useEffect(() => {
    const aj = searchParams?.get('autoJoin');
    if (!orderId || !aj) return;
    (async () => {
      const sess = await supabase.auth.getSession();
      if (!sess.data.session) return;
      await supabase.rpc('join_order', { p_order_id: orderId, p_role: aj as any });
      await load();
    })();
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [orderId]);async function load() {
    if (!orderId) return;

    // 1) Order
    const o = await supabase
      .from("orders")
      .select("id,status,subtotal,currency")
      .eq("id", orderId)
      .single();
    if (!o.error) setOrder(o.data as Order);
    else setOrder(null);

    // 2) Vue ($)
    const v = await supabase
      .from("v_order_commission_summary")
      .select("*")
      .eq("order_id", orderId)
      .maybeSingle();

    if (!v.error && v.data) {
      setComm(v.data as CommissionRow);
      return;
    }

    // 3) Fallback (cents)
    const t = await supabase
      .from("order_commissions")
      .select("*")
      .eq("order_id", orderId)
      .maybeSingle();

    if (!t.error && t.data) {
      const d = t.data as CommissionRow;
      setComm({
        ...d,
        client_amount: (d.client_cents ?? 0) / 100,
        driver_amount: (d.driver_cents ?? 0) / 100,
        restaurant_amount: (d.restaurant_cents ?? 0) / 100,
        platform_amount: (d.platform_cents ?? 0) / 100,
      });
    } else {
      setComm(null);
    }
  }

  useEffect(() => {
    if (!orderId) return;
    load();
    const ch = supabase
      .channel(`order:${orderId}`)
      .on("postgres_changes", { event: "UPDATE", schema: "public", table: "orders", filter: `id=eq.${orderId}` }, () => load())
      .on("postgres_changes", { event: "INSERT", schema: "public", table: "order_commissions", filter: `order_id=eq.${orderId}` }, () => load())
      .on("postgres_changes", { event: "UPDATE", schema: "public", table: "order_commissions", filter: `order_id=eq.${orderId}` }, () => load())
      .subscribe();
    return () => { supabase.removeChannel(ch); };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [orderId]);

  const updateStatus = async (status: Order["status"]) => {
    const { error } = await supabase.from("orders").update({ status }).eq("id", orderId);
    if (error) alert(error.message);
  };

  // Si l'URL n'a pas d'orderId, on arrête là
  if (!orderId) {
    return (
      <div className="max-w-4xl mx-auto p-4 space-y-6">
        <h1 className="text-2xl font-bold">Commande #</h1>
        <div className="p-4 rounded-2xl border bg-amber-50">
          <div className="font-medium mb-2">Accès requis</div>
          <p className="text-sm text-gray-700">orderId manquant dans l’URL. Ouvre la page via /orders/&lt;UUID&gt;.</p>
        </div>
      </div>
    );
  }

  return (
    <div className="max-w-4xl mx-auto p-4 space-y-6">
      <h1 className="text-2xl font-bold">Commande #{orderId}</h1>

{/* Toolbar adhésion (membre / non-membre) */}
<OrderMembershipToolbar orderId={orderId} />


      {/* Toolbar */}
      <div className="flex flex-wrap gap-2 mt-2">
        <button
          className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm"
          onClick={async () => {
            const { error } = await supabase.rpc("refresh_order_commissions", { p_order_id: orderId });
            if (error) { alert(error.message); return; }
            await load();
          }}
        >
          Recalculer via RPC
        </button>

        <button
          className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm"
          onClick={async () => {
            const n = prompt("Nouveau sous-total (ex: 149.99):", "149.99");
            if (!n) return;
            const subtotal = Number(n);
            if (Number.isNaN(subtotal)) { alert("Nombre invalide"); return; }
            const { error } = await supabase.from("orders").update({ subtotal }).eq("id", orderId);
            if (error) { alert(error.message); return; }
            await load();
          }}
        >
          Changer le sous-total
        </button>

        {!order || !comm ? (
          <>
            <button
              className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm"
              onClick={async () => {
                const s = await supabase.auth.getSession();
                if (!s.data.session) { alert("Connecte-toi d’abord dans le chat (magic link)."); return; }
                const { error } = await supabase.rpc("join_order", { p_order_id: orderId, p_role: "driver" });
                if (error) { alert(error.message); return; }
                await load();
              }}
            >
              Rejoindre (driver)
            </button>
            <button
              className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm"
              onClick={async () => {
                const s = await supabase.auth.getSession();
                if (!s.data.session) { alert("Connecte-toi d’abord dans le chat (magic link)."); return; }
                const { error } = await supabase.rpc("join_order", { p_order_id: orderId, p_role: "client" });
                if (error) { alert(error.message); return; }
                await load();
              }}
            >
              Rejoindre (client)
            </button>
            <button
              className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm"
              onClick={async () => {
                const s = await supabase.auth.getSession();
                if (!s.data.session) { alert("Connecte-toi d’abord dans le chat (magic link)."); return; }
                const { error } = await supabase.rpc("join_order", { p_order_id: orderId, p_role: "restaurant" });
                if (error) { alert(error.message); return; }
                await load();
              }}
            >
              Rejoindre (restaurant)
            </button>
            <button
              className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm"
              onClick={() => { window.location.href = `/orders/${orderId}/chat`; }}
            >
              Ouvrir le chat pour se connecter
            </button>
          </>
        ) : null}
      </div>

      {(!order || !comm) && (
        <div className="p-4 rounded-2xl border bg-amber-50">
          <div className="font-medium mb-2">Accès requis</div>
          <p className="text-sm text-gray-700">
            Tu dois être membre de la commande pour voir le montant et les commissions.
          </p>
        </div>
      )}

      <section className="grid md:grid-cols-3 gap-4">
        <div className="p-4 rounded-2xl border">
          <div className="text-sm text-gray-500">Statut</div>
          <div className="text-xl font-semibold">{order?.status ?? "—"}</div>
          <div className="mt-3 flex flex-wrap gap-2">
            {["pending","accepted","prepared","ready","dispatched","delivered","canceled"].map((s) => (
              <button key={s} onClick={() => updateStatus(s as Order["status"])} className="px-3 py-1.5 rounded-xl border hover:bg-gray-50">
                {s}
              </button>
            ))}
          </div>
        </div>

        <div className="p-4 rounded-2xl border">
          <div className="text-sm text-gray-500">Montant</div>
          <div className="text-xl font-semibold">
            {order ? `${order.subtotal.toFixed(2)} ${order.currency}` : "—"}
          </div>
        </div>

        <div className="p-4 rounded-2xl border">
          <div className="text-sm text-gray-500">Commissions (plateforme = client + driver + restaurant)</div>
          {comm ? (
            <ul className="mt-2 text-sm">
              <li>Client: {to2(comm.client_amount)} {comm.currency}</li>
              <li>Driver: {to2(comm.driver_amount)} {comm.currency}</li>
              <li>Restaurant: {to2(comm.restaurant_amount)} {comm.currency}</li>
              <li className="font-semibold">Plateforme: {to2(comm.platform_amount)} {comm.currency}</li>
              {comm.updated_at ? (
                <li className="text-xs text-gray-500 mt-1">Maj: {new Date(comm.updated_at).toLocaleString()}</li>
              ) : null}
            </ul>
          ) : (
            <div className="text-sm text-gray-500">Pas de données.</div>
          )}
        </div>
      </section>
{/* Members block */}
<div className="mt-4">
  <MembersList orderId={orderId} />
</div>

    </div>
  );
}

function OrderMembershipToolbar({ orderId }: { orderId: string }) {
  const { isMember, loading, join, leave } = useOrderMembership(orderId);

  if (loading) {
    return <div className="text-sm text-gray-500">Vérification de l’adhésion…</div>;
  }

  if (!isMember) {
    return (
      <div className="flex flex-wrap gap-2 mt-2">
        <button onClick={() => join("driver")} className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm">Rejoindre (driver)</button>
        <button onClick={() => join("client")} className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm">Rejoindre (client)</button>
        <button onClick={() => join("restaurant")} className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm">Rejoindre (restaurant)</button>
        <a href={`/orders/${orderId}/chat`} className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm">Ouvrir le chat pour se connecter</a>
      </div>
    );
  }

  return (
    <div className="flex items-center gap-3 mt-2">
      <span className="text-sm text-green-700">Membre ✔</span>
      <button
        onClick={async () => {
          try { await leave(); } catch (e: any) { alert(e?.message ?? "Erreur leave"); }
        }}
        className="px-3 py-1.5 rounded-xl border hover:bg-gray-50 text-sm"
      >
        Quitter la commande
      </button>
    </div>
  );
}




