'use client';

import { useEffect, useRef, useState } from 'react';
import { supabase } from '../lib/supabaseBrowser';

type Msg = {
  id: number;
  order_id: string;
  user_id: string;
  message: string;
  created_at: string;
  image_path?: string | null;
  // client-only
  _optimistic?: boolean;
  _signedUrl?: string | null;
};

type Profile = { id: string; full_name?: string | null; avatar_url?: string | null };

function getInitials(name?: string | null) {
  if (!name) return '';
  const parts = name.trim().split(/\s+/).filter(Boolean).slice(0, 2);
  if (parts.length === 0) return '';
  return parts.map(p => p[0]).join('').toUpperCase();
}

function formatTs(ts: string) {
  const d = new Date(ts);
  return isNaN(d.getTime()) ? ts : d.toLocaleString();
}

function Avatar({ name, url }: { name?: string | null; url?: string | null }) {
  const initials = getInitials(name);
  return url ? (
    <img
      src={url}
      alt={name ?? 'avatar'}
      className="h-8 w-8 rounded-full object-cover ring-1 ring-black/5"
    />
  ) : (
    <div className="h-8 w-8 rounded-full bg-gray-300 grid place-items-center text-xs font-semibold text-gray-700">
      {initials || '👤'}
    </div>
  );
}

// petit "beep" via WebAudio (pas besoin de fichier)
async function ping() {
  try {
    const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
    const o = ctx.createOscillator();
    const g = ctx.createGain();
    o.type = 'sine';
    o.frequency.value = 880;
    o.connect(g);
    g.connect(ctx.destination);
    g.gain.setValueAtTime(0.0001, ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.05, ctx.currentTime + 0.01);
    o.start();
    g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.18);
    o.stop(ctx.currentTime + 0.2);
  } catch {}
}

export default function Messages({ orderId }: { orderId: string }) {
  const [msgs, setMsgs] = useState<Msg[]>([]);
  const [profiles, setProfiles] = useState<Record<string, Profile>>({});
  const [currentUserId, setCurrentUserId] = useState<string | null>(null);
  const [isMember, setIsMember] = useState<boolean | null>(null); // null = inconnu
  const [text, setText] = useState('');
  const [file, setFile] = useState<File | null>(null);
  const [err, setErr] = useState<string | null>(null);
  const [sending, setSending] = useState(false);

  const listRef = useRef<HTMLDivElement>(null);
  const inputRef = useRef<HTMLInputElement>(null);
  const fileRef = useRef<HTMLInputElement>(null);
  const mounted = useRef(true);
  const lastCountRef = useRef<number>(0);

  // Scroll fluide quand la liste évolue
  useEffect(() => {
    const el = listRef.current;
    if (el) el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' });
  }, [msgs.length]);

  // Focus champ texte au chargement
  useEffect(() => { inputRef.current?.focus(); }, []);

  // Préparer notifications (si autorisées)
  useEffect(() => {
    if (typeof Notification !== 'undefined' && Notification.permission === 'default') {
      Notification.requestPermission().catch(() => {});
    }
  }, []);

  // Récupère utilisateur + membership
  useEffect(() => {
    (async () => {
      const { data: { user } } = await supabase.auth.getUser();
      const uid = user?.id ?? null;
      setCurrentUserId(uid);

      if (uid) {
        const { data: mem, error: memErr } = await supabase
          .from('order_members')
          .select('order_id')
          .eq('order_id', orderId)
          .eq('user_id', uid)
          .limit(1);
        if (memErr) {
          console.warn('order_members read policy?', memErr);
          setIsMember(false);
        } else {
          setIsMember(!!mem?.length);
        }
      } else {
        setIsMember(false);
      }
    })();
  }, [orderId]);

  async function signImages(rows: Msg[]) {
    const withUrls: Msg[] = [];
    for (const m of rows) {
      if (m.image_path) {
        const { data: signed, error: sErr } = await supabase
          .storage.from('chat-images')
          .createSignedUrl(m.image_path, 60 * 60); // 1h
        withUrls.push({ ...m, _signedUrl: sErr ? null : signed?.signedUrl ?? null });
      } else {
        withUrls.push(m);
      }
    }
    return withUrls;
  }

  async function load() {
    setErr(null);
    const { data, error } = await supabase
      .from('order_messages')
      .select('id, order_id, user_id, message, created_at, image_path')
      .eq('order_id', orderId)
      .order('created_at', { ascending: true });

    if (error) {
      console.error('load messages error:', error);
      setErr(error.message);
      return;
    }
    if (!mounted.current) return;

    const withSigned = await signImages(data ?? []);
    setMsgs(withSigned);
  }

  async function send() {
    try {
      // gardes-fous texte
      const cleaned = text.replace(/\s+/g, ' ').trim();
      const hasText = cleaned.length > 0;
      if (hasText && cleaned.length > 500) {
        throw new Error('Message trop long (max 500 caractères).');
      }

      setSending(true);
      setErr(null);

      const { data: { user }, error: uerr } = await supabase.auth.getUser();
      if (uerr) throw uerr;
      if (!user) throw new Error('Veuillez vous connecter.');

      // Vérifie membership
      const { data: mem, error: memErr } = await supabase
        .from('order_members')
        .select('order_id')
        .eq('order_id', orderId)
        .eq('user_id', user.id)
        .limit(1);
      if (memErr) throw memErr;
      if (!mem?.length) {
        setIsMember(false);
        throw new Error("Tu dois rejoindre la commande avant d'écrire.");
      }

      // Si image, vérifier type/taille et uploader
      let uploadedPath: string | null = null;
      if (file) {
        if (!file.type.startsWith('image/')) throw new Error('Fichier non supporté (image uniquement).');
        if (file.size > 5 * 1024 * 1024) throw new Error('Image trop lourde (max 5 MB).');

        const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_').toLowerCase();
        const storagePath = `${orderId}/${user.id}/${Date.now()}_${safeName}`;
        const { error: upErr } = await supabase
          .storage
          .from('chat-images')
          .upload(storagePath, file, { upsert: false, cacheControl: '3600' });
        if (upErr) throw upErr;
        uploadedPath = storagePath;
      }

      // Pas de message vide: si juste image, on met un placeholder
      const finalText = hasText ? cleaned : (uploadedPath ? '📷 image' : '');
      if (!finalText) throw new Error('Écris un message ou choisis une image.');

      // Optimistic UI (sans URL signée immédiate)
      const optimistic: Msg = {
        id: Date.now(),
        order_id: orderId,
        user_id: user.id,
        message: finalText,
        created_at: new Date().toISOString(),
        image_path: uploadedPath,
        _optimistic: true,
        _signedUrl: null,
      };
      setMsgs(prev => [...prev, optimistic]);
      setText('');
      setFile(null);
      fileRef.current && (fileRef.current.value = '');

      const { error } = await supabase
        .from('order_messages')
        .insert({ order_id: orderId, user_id: user.id, message: finalText, image_path: uploadedPath });
      if (error) throw error;

      // Resync pour récupérer la signedUrl
      await load();
    } catch (e: any) {
      setErr(e?.message ?? String(e));
    } finally {
      setSending(false);
    }
  }

  // Initial + realtime
  useEffect(() => {
    mounted.current = true;
    void load();

    const ch = supabase
      .channel(`omsg_${orderId}`)
      .on(
        'postgres_changes',
        { event: 'INSERT', schema: 'public', table: 'order_messages', filter: `order_id=eq.${orderId}` },
        async (payload: any) => {
          // Notif + son si nouveau message d'un autre utilisateur
          const other = payload?.new?.user_id && payload.new.user_id !== currentUserId;
          if (other) {
            ping();
            if (typeof Notification !== 'undefined' && Notification.permission === 'granted') {
              try {
                new Notification('Nouveau message', { body: payload.new.message || 'Image', silent: true });
              } catch {}
            }
          }
          await load();
        }
      )
      .on(
        'postgres_changes',
        { event: 'UPDATE', schema: 'public', table: 'order_messages', filter: `order_id=eq.${orderId}` },
        () => load()
      )
      .subscribe();

    return () => {
      mounted.current = false;
      supabase.removeChannel(ch);
    };
  }, [orderId, currentUserId]);

  const inputDisabled = sending || !text.trim() && !file || isMember === false;

  return (
    <div className="space-y-3">
      <div ref={listRef} className="max-h-80 overflow-auto border rounded-lg p-3 bg-white">
        {msgs.length === 0 ? (
          <p className="text-sm text-gray-500 italic">Aucun message pour le moment.</p>
        ) : (
          <ul className="space-y-3">
            {msgs.map((m) => {
              const prof = profiles[m.user_id];
              const name = (prof?.full_name || m.user_id.slice(0, 8)) + (m.user_id === currentUserId ? '' : '');
              const isMine = m.user_id === currentUserId;

              return (
                <li key={m.id} className={`flex gap-2 ${isMine ? 'justify-end' : 'justify-start'}`}>
                  {!isMine && <Avatar name={prof?.full_name} url={prof?.avatar_url} />}

                  <div className={`max-w-[80%] ${isMine ? 'items-end text-right' : 'items-start text-left'} flex flex-col`}>
                    <div className="text-[11px] text-gray-500">{name}</div>

                    <div
                      className={[
                        'rounded-2xl px-3 py-2 text-sm shadow-sm leading-relaxed',
                        isMine ? 'bg-black text-white rounded-br-sm' : 'bg-gray-100 text-gray-900 rounded-bl-sm',
                        m._optimistic ? 'opacity-70' : ''
                      ].join(' ')}
                    >
                      <div>{m.message}</div>
                      {m.image_path && (
                        <div className="mt-2">
                          {m._signedUrl ? (
                            <img
                              src={m._signedUrl}
                              alt="image du message"
                              className="rounded-lg max-h-64 ring-1 ring-black/5"
                              loading="lazy"
                            />
                          ) : (
                            <div className="text-xs text-gray-400 italic">Image…</div>
                          )}
                        </div>
                      )}
                      <div className={`mt-1 text-[10px] ${isMine ? 'text-gray-300' : 'text-gray-500'}`}>
                        {formatTs(m.created_at)}{m._optimistic ? ' • envoi…' : ''}
                      </div>
                    </div>

                    {/* avatar à droite si c’est moi */}
                    {isMine && <Avatar name={prof?.full_name} url={prof?.avatar_url} />}
                  </div>
                </li>
              );
            })}
          </ul>
        )}
      </div>

      {isMember === false && (
        <p className="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-md p-2">
          Tu dois <strong>rejoindre la commande</strong> avant d’écrire.
        </p>
      )}

      {/* Input texte + image */}
      <div className="flex flex-wrap gap-2 items-center">
        <input
          ref={inputRef}
          value={text}
          onChange={(e) => setText(e.target.value)}
          onKeyDown={(e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
              e.preventDefault();
              send();
            }
          }}
          placeholder="Écrire un message…"
          className="flex-1 min-w-[240px] border rounded-lg px-3 py-2"
          disabled={isMember === false}
        />
        <input
          ref={fileRef}
          type="file"
          accept="image/*"
          onChange={(e) => setFile(e.target.files?.[0] ?? null)}
          className="text-sm"
          disabled={isMember === false}
        />
        <button
          onClick={send}
          disabled={inputDisabled}
          className="px-4 py-2 rounded-lg bg-black text-white disabled:opacity-50"
        >
          Envoyer
        </button>
      </div>

      {/* Aperçu image sélectionnée */}
      {file && (
        <div className="flex items-center gap-3 text-xs text-gray-600">
          <span>Aperçu:</span>
          <img
            src={URL.createObjectURL(file)}
            alt="aperçu"
            className="h-12 rounded-md ring-1 ring-black/5"
          />
          <button onClick={() => { setFile(null); fileRef.current && (fileRef.current.value = ''); }} className="underline">
            Retirer
          </button>
        </div>
      )}

      {err && <p className="text-red-600 text-sm">Erreur : {err}</p>}
    </div>
  );
}
