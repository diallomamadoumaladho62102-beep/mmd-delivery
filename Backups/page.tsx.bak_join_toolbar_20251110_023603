"use client";

import React, { useEffect, useMemo } from "react";
import { useParams, useRouter } from "next/navigation";
import type { User } from "@supabase/supabase-js";
import { supabase } from "@/lib/supabaseBrowser";
import ChatMessages from "@/components/ChatMessages";
import CommissionSummary from "@/components/CommissionSummary";
import ChatInput from "@/components/ChatInput";

const UUID_RE =
  /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;

export default function OrderChatPage() {
  const params = useParams<{ orderId: string }>();
  const raw = params?.orderId ?? "";
  const orderId = decodeURIComponent(raw || "");
  const isUuid = useMemo(() => UUID_RE.test(orderId), [orderId]);

  // recalcul commissions (best-effort, silencieux si RLS bloque)
  useEffect(() => {
    if (!isUuid) return;
    (async () => {
      try {
        const { error } = await supabase.rpc("refresh_order_commissions", {
          p_order_id: orderId,
        });
        if (error) {
          // console.debug("refresh_order_commissions:", error.message);
        }
      } catch {/* ignore */}
    })();
  }, [isUuid, orderId]);

  if (!isUuid) return <InvalidPanel />;

  return (
    <div className="max-w-3xl mx-auto p-4 space-y-6">
      <h1 className="text-xl font-bold">Chat — commande #{orderId}</h1>
      <AuthBanner />
      <JoinToolbar orderId={orderId} />
      <CommissionSummary orderId={orderId} />
      <ChatMessages orderId={orderId} />
      <ChatInput orderId={orderId} onSent={() => {}} />
    </div>
  );
}

function AuthBanner() {
  const [user, setUser] = React.useState<User | null>(null);
  useEffect(() => {
    supabase.auth.getUser().then(({ data }) => setUser(data.user ?? null));
  }, []);
  if (user) return null;
  return (
    <div className="p-3 border rounded-lg bg-yellow-50 text-sm">
      <div className="font-medium mb-1">Non connecté</div>
      <div className="flex flex-wrap gap-4">
        <a className="underline text-blue-700" href="/auth/sign-in-password">
          Se connecter (email + mot de passe)
        </a>
        <a className="underline text-blue-700" href="/auth/sign-in">
          Autres méthodes
        </a>
      </div>
    </div>
  );
}

function JoinToolbar({ orderId }: { orderId: string }) {
  const router = useRouter();
  const [busy, setBusy] = React.useState<string | null>(null);
  const [msg, setMsg] = React.useState<string | null>(null);

  async function join(role: "driver" | "client" | "restaurant") {
    setMsg(null);
    setBusy(role);
    try {
      const s = await supabase.auth.getSession();
      if (!s.data.session) {
        alert(
          "Connecte-toi d’abord (par exemple via le lien magique depuis la page /auth), puis réessaie."
        );
        return;
      }
      const { data, error } = await supabase.rpc("join_order", {
        p_order_id: orderId,
        p_role: role,
      });
      if (error) {
        alert(error.message);
        return;
      }
      setMsg(`Rejoint comme ${role} ✔`);
      // rafraîchir les sections (CommissionSummary/Chat) qui dépendent des droits
      router.refresh();
    } finally {
      setBusy(null);
    }
  }

  return (
    <div className="border rounded-xl p-3 bg-gray-50">
      <div className="text-sm text-gray-700 mb-2">
        Deviens membre de la commande :
      </div>
      <div className="flex flex-wrap gap-2">
        <button
          onClick={() => join("driver")}
          disabled={busy !== null}
          className="px-3 py-1.5 rounded-xl border hover:bg-white disabled:opacity-60"
        >
          {busy === "driver" ? "..." : "Rejoindre (driver)"}
        </button>
        <button
          onClick={() => join("client")}
          disabled={busy !== null}
          className="px-3 py-1.5 rounded-xl border hover:bg-white disabled:opacity-60"
        >
          {busy === "client" ? "..." : "Rejoindre (client)"}
        </button>
        <button
          onClick={() => join("restaurant")}
          disabled={busy !== null}
          className="px-3 py-1.5 rounded-xl border hover:bg-white disabled:opacity-60"
        >
          {busy === "restaurant" ? "..." : "Rejoindre (restaurant)"}
        </button>
        <a
          href={`/orders/${orderId}`}
          className="px-3 py-1.5 rounded-xl border hover:bg-white"
        >
          Ouvrir la page commande
        </a>
      </div>
      {msg && <div className="text-xs text-green-700 mt-2">{msg}</div>}
    </div>
  );
}

function InvalidPanel() {
  const router = useRouter();
  const [val, setVal] = React.useState(
    "a80cf7e1-6195-433f-907f-be61fcabf470"
  );
  const valid = UUID_RE.test(val);
  return (
    <div className="max-w-3xl mx-auto p-6 space-y-4">
      <h1 className="text-xl font-bold">Chat — commande</h1>
      <div className="p-4 border rounded-lg space-y-3">
        <div className="text-red-600 font-medium">ID de commande invalide</div>
        <p className="text-sm text-gray-700">
          Colle un UUID de commande ci-dessous ou passe par Admin → Orders.
        </p>
        <input
          className="w-full border rounded px-3 py-2"
          placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
          value={val}
          onChange={(e) => setVal(e.target.value)}
        />
        <div className="flex flex-wrap gap-2">
          <button
            className="px-3 py-2 rounded bg-black text-white disabled:opacity-50"
            disabled={!valid}
            onClick={() =>
              router.push(`/orders/${encodeURIComponent(val)}/chat`)
            }
          >
            Ouvrir
          </button>
          <a className="underline text-blue-600 px-3 py-2" href="/admin/orders">
            Aller à Admin → Orders
          </a>
          <a
            className="underline text-blue-600 px-3 py-2"
            href="/orders/create-errand"
          >
            Créer une commande
          </a>
        </div>
      </div>
    </div>
  );
}
