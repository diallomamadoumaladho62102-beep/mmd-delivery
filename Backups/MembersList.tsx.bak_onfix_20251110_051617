"use client";
import * as React from "react";
import { supabase } from "@/lib/supabaseBrowser";

type Member = {
  member_id: string;
  order_id: string;
  user_id: string;
  role: "client"|"driver"|"restaurant"|"admin";
  joined_at: string;
  full_name: string | null;
  avatar_url: string | null;
};

export default function MembersList({ orderId }: { orderId: string }) {
  const [rows, setRows] = React.useState<Member[]>([]);
  const [me, setMe] = React.useState<string | null>(null);
  const [loading, setLoading] = React.useState(true);

  async function load() {
    setLoading(true);
    try {
      const u = (await supabase.auth.getUser()).data.user;
      setMe(u?.id ?? null);

      const { data, error } = await supabase
        .from("v_order_members_detailed")
        .select("*")
        .eq("order_id", orderId)
        .order("joined_at", { ascending: true });

      if (error) throw error;
      setRows((data ?? []) as Member[]);
    } catch (e) {
      setRows([]);
    } finally {
      setLoading(false);
    }
  }

  React.useEffect(() => {
    load();
    const ch = supabase
      .channel(`members:${orderId}`)
      .on({ event: "INSERT", schema: "public", table: "order_members", filter: `order_id=eq.${orderId}` }, () => load())
      .on({ event: "UPDATE", schema: "public", table: "order_members", filter: `order_id=eq.${orderId}` }, () => load())
      .on({ event: "DELETE", schema: "public", table: "order_members", filter: `order_id=eq.${orderId}` }, () => load())
      .subscribe();
    return () => { supabase.removeChannel(ch); };
  }, [orderId]);

  const changeRole = async (role: Member["role"]) => {
    const { error } = await supabase.rpc("change_my_role", { p_order_id: orderId, p_role: role });
    if (error) { alert(error.message); return; }
    await load();
  };

  return (
    <div className="p-4 rounded-2xl border">
      <div className="font-semibold mb-2">Membres</div>
      {loading ? <div className="text-sm text-gray-500">Chargement…</div> : null}
      {rows.length === 0 && !loading ? <div className="text-sm text-gray-500">Aucun membre.</div> : null}
      <ul className="space-y-2">
        {rows.map((m) => (
          <li key={m.member_id} className="flex items-center justify-between border rounded-lg p-2">
            <div className="flex items-center gap-3">
              {m.avatar_url ? (
                <img src={m.avatar_url} alt="" className="w-8 h-8 rounded-full border object-cover" />
              ) : (
                <div className="w-8 h-8 rounded-full border bg-gray-50" />
              )}
              <div>
                <div className="text-sm font-medium">{m.full_name || m.user_id.slice(0,8)}</div>
                <div className="text-xs text-gray-500">{m.role} • {new Date(m.joined_at).toLocaleString()}</div>
              </div>
            </div>
            {me === m.user_id ? (
              <div className="flex gap-1">
                {(["client","driver","restaurant","admin"] as const).map(r => (
                  <button
                    key={r}
                    onClick={() => changeRole(r)}
                    className={"px-2 py-1 rounded border text-xs " + (m.role===r ? "bg-black text-white" : "hover:bg-gray-50")}
                    title={r}
                  >
                    {r}
                  </button>
                ))}
              </div>
            ) : null}
          </li>
        ))}
      </ul>
    </div>
  );
}
