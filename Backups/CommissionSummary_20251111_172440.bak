"use client";

import { useEffect, useState } from "react";
import { supabase } from "@/lib/supabaseBrowser";

type Commission = {
  order_id: string;
  status: string | null;
  amount_client: number | null;
  amount_driver: number | null;
  amount_restaurant: number | null;
  amount_platform: number | null;
  pct_client: number | null;
  pct_driver: number | null;
  pct_restaurant: number | null;
  pct_platform: number | null;
  currency: string | null;
  updated_at: string | null;
};

export default function CommissionSummary({ orderId }: { orderId: string }) {
  const [data, setData] = useState<Commission | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  async function load() {
    setError(null);
    setIsLoading(true);

    // 1) Tente de lire la vue
    const { data: rows, error: selErr } = await supabase
      .from("v_order_commissions")
      .select("*")
      .eq("order_id", orderId)
      .limit(1);

    if (selErr) {
      setError(selErr.message);
      setData(null);
      setIsLoading(false);
      return;
    }

    if (!rows || rows.length === 0) {
      // 2) Rien encore -> on force un refresh et on relit
      const { error: rpcErr } = await supabase.rpc("refresh_order_commissions", { p_order_id: orderId });
      if (rpcErr) {
        setError(rpcErr.message);
        setData(null);
        setIsLoading(false);
        return;
      }
      const { data: rows2, error: selErr2 } = await supabase
        .from("v_order_commissions")
        .select("*")
        .eq("order_id", orderId)
        .limit(1);
      if (selErr2) {
        setError(selErr2.message);
        setData(null);
        setIsLoading(false);
        return;
      }
      setData(rows2?.[0] ?? null);
      setIsLoading(false);
      return;
    }

    setData(rows[0]);
    setIsLoading(false);
  }

  useEffect(() => {
    load();
    // Realtime: si commissions changent
    const ch = supabase
      .channel(`comm:${orderId}`)
      .on("postgres_changes",
        { event: "*", schema: "public", table: "order_commissions", filter: `order_id=eq.${orderId}` },
        () => load()
      )
      .subscribe();
    return () => { supabase.removeChannel(ch); };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [orderId]);

  const recalc = async () => {
    setError(null);
    const { error: rpcErr } = await supabase.rpc("refresh_order_commissions", { p_order_id: orderId });
    if (rpcErr) { setError(rpcErr.message); return; }
    await load();
  };

  if (isLoading) return <div className="text-sm opacity-70">Chargement des commissions…</div>;
  if (error) return (
    <div className="text-sm text-red-600">
      Erreur: {error} <button className="underline ml-2" onClick={load}>Réessayer</button>
    </div>
  );
  if (!data) return (
    <div className="text-sm">
      Pas de données de commission. <button className="underline" onClick={recalc}>Calculer</button>
    </div>
  );

  const money = (n: number | null | undefined) =>
    (n ?? 0).toLocaleString(undefined, { style: "currency", currency: data.currency || "USD" });

  return (
    <div className="border rounded p-3 space-y-2">
      <div className="flex items-center justify-between">
        <h3 className="font-semibold">Commissions</h3>
        <button onClick={recalc} className="text-sm border rounded px-2 py-1">Recalculer</button>
      </div>
      <div className="grid grid-cols-2 gap-2 text-sm">
        <div>Client ({data.pct_client ?? 0}%):</div><div className="text-right">{money(data.amount_client)}</div>
        <div>Driver ({data.pct_driver ?? 0}%):</div><div className="text-right">{money(data.amount_driver)}</div>
        <div>Restaurant ({data.pct_restaurant ?? 0}%):</div><div className="text-right">{money(data.amount_restaurant)}</div>
        <div>Plateforme ({data.pct_platform ?? 0}%):</div><div className="text-right">{money(data.amount_platform)}</div>
      </div>
      <div className="text-xs opacity-70">
        Devise: {data.currency || "USD"} • MAJ: {data.updated_at ? new Date(data.updated_at).toLocaleString() : "—"}
      </div>
    </div>
  );
}
