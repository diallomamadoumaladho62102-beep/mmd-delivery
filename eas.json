{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL_LOCAL": "http://192.168.1.203:3000",
        "EXPO_PUBLIC_API_URL_PROD": "https://www.mmddelivery.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "production",
      "env": {
        "APP_ENV": "production",
        "EAS_BUILD_PROFILE": "preview",
        "EXPO_PUBLIC_API_URL_PROD": "https://www.mmddelivery.com",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "android-smoke": {
      "distribution": "internal",
      "environment": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production",
        "EAS_BUILD_PROFILE": "preview",
        "EXPO_PUBLIC_API_URL_PROD": "https://www.mmddelivery.com",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "ios-simulator": {
      "distribution": "internal",
      "environment": "production",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_ENV": "production",
        "EAS_BUILD_PROFILE": "preview",
        "EXPO_PUBLIC_API_URL_PROD": "https://www.mmddelivery.com",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "EAS_BUILD_PROFILE": "production",
        "EXPO_PUBLIC_API_URL_PROD": "https://www.mmddelivery.com",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6761693075"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
