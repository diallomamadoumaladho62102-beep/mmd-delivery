{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["react", "react-native"]
  },
  "include": ["src", "App.tsx", "index.js"],
  "exclude": [
    "node_modules",
    "**/*.OLD.tsx",
    "**/*.backup.tsx",
    "**/__backup_chatfix_*",
    "**/__backup_*"
  ]
}